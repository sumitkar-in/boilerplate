NODE_ENV=development

# Core database (also used as the connection root; tenant schemas live in the same DB)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app_db
REDIS_URL=redis://localhost:6379

# Signs access tokens (15m) and 2FA-pending tokens (5m). Refresh tokens are
# opaque, DB-tracked, hashed values — not JWTs — so there's no separate
# refresh secret to configure. Required in production (min 32 chars) — the
# API refuses to boot without it when NODE_ENV=production.
JWT_SECRET=change_me

# Optional — all have code-level defaults, uncomment to override.
# The full env contract is apps/api/src/core/config/env.validation.ts.
# PORT=3000
# APP_NAME=Boilerplate               # shown as the 2FA issuer in authenticator apps
# API_DOCS_ENABLED=false             # keep Swagger disabled in production unless explicitly needed
# NESTLENS_ENABLED=true              # ignored in production; dashboard still requires super-admin auth
# ACCESS_TOKEN_TTL_SECONDS=900
# REFRESH_TOKEN_TTL_DAYS=30
# TENANT_BASE_DOMAIN=example.com   # enables subdomain-based tenant resolution (acme.example.com)

WEB_URL=https://localhost
API_URL=https://localhost/api

# Frontend build-time env (Vite / Expo read these directly, not the API).
# VITE_API_URL=https://localhost/api        # web app API base; defaults to /api/v1 same-origin
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000  # mobile app API base (Android emulator loopback)

# Compose profiles — comma-separated, run via `pnpm docker:up`.
#   minio: local S3-compatible object storage, internal-only unless explicitly
#          proxied through Nginx.
OBSERVABILITY_ENABLED=false
AI_ENABLED=false
AI_SERVICE_URL=http://ai:8000
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:0.6b
LOKI_URL=http://loki:3100
LOG_LEVEL=info
PROMETHEUS_RETENTION_TIME=24h
LOKI_RETENTION_PERIOD=24h
GRAFANA_DASHBOARD_TIME_FROM=now-24h
GRAFANA_ADMIN_USER=admin
INFRA_ADMIN_PASSWORD=admin123
GRAFANA_VIEWER_USER=viewer
GRAFANA_VIEWER_PASSWORD=viewer123
GRAFANA_VIEWER_EMAIL=viewer@example.local

# pgAdmin is internal-only. Pre-registered against the `postgres` service;
# local dev only.
PGADMIN_DEFAULT_EMAIL=admin@example.com

# Storage configuration (local filesystem or S3/MinIO object storage)
STORAGE_DRIVER=local
# If using S3 driver and running local MinIO in Docker, enable minio:
MINIO_ENABLED=false
# Set true only for public demo assets. Leave false for confidential uploads.
S3_PUBLIC_READ_ENABLED=false
# COMPOSE_PROFILES=minio
S3_ENDPOINT=http://minio:9000
S3_BUCKET=app-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
