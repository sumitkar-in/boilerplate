{
  "title": "API Overview",
  "uid": "api-overview",
  "editable": true,
  "timezone": "browser",
  "schemaVersion": 39,
  "time": { "from": "__GRAFANA_DASHBOARD_TIME_FROM__", "to": "now" },
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "env",
        "label": "Environment",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({app=\"api\"}, env)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "level",
        "label": "Level",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({app=\"api\", env=~\"$env\"}, level)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "method",
        "label": "Method",
        "type": "custom",
        "query": "GET,POST,PATCH,PUT,DELETE,OPTIONS",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "tenant",
        "label": "Tenant",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_requests_total, tenant_slug)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "status",
        "label": "Status",
        "type": "textbox",
        "query": ".*",
        "current": { "selected": false, "text": ".*", "value": ".*" }
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "query": "",
        "current": { "selected": false, "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request rate by route",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (route, status_code) (rate(http_requests_total{tenant_slug=~\"$tenant\"}[5m]))",
          "legendFormat": "{{route}} [{{status_code}}]"
        }
      ]
    },
    {
      "id": 2,
      "title": "p95 request duration",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket{tenant_slug=~\"$tenant\"}[5m])))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "CPU usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(process_cpu_user_seconds_total{job=\"api\"}[5m]) + rate(process_cpu_system_seconds_total{job=\"api\"}[5m]))",
          "legendFormat": "CPU"
        }
      ]
    },
    {
      "id": 5,
      "title": "Memory",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_resident_memory_bytes{job=\"api\"}",
          "legendFormat": "RSS"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nodejs_heap_size_used_bytes{job=\"api\"}",
          "legendFormat": "Heap used"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nodejs_external_memory_bytes{job=\"api\"}",
          "legendFormat": "External"
        }
      ]
    },
    {
      "id": 6,
      "title": "Event loop lag",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nodejs_eventloop_lag_seconds{job=\"api\"}",
          "legendFormat": "Current"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nodejs_eventloop_lag_p99_seconds{job=\"api\"}",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 7,
      "title": "Request rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{tenant_slug=~\"$tenant\"}[5m]))",
          "legendFormat": "requests/sec"
        }
      ]
    },
    {
      "id": 8,
      "title": "Error rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(http_requests_total{tenant_slug=~\"$tenant\", status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{tenant_slug=~\"$tenant\"}[5m])), 0.001)",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 9,
      "title": "Active handles",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 15 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nodejs_active_handles{job=\"api\"}",
          "legendFormat": "handles"
        }
      ]
    },
    {
      "id": 10,
      "title": "Active requests",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 15 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nodejs_active_requests{job=\"api\"}",
          "legendFormat": "requests"
        }
      ]
    },
    {
      "id": 11,
      "title": "Heap size",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nodejs_heap_size_used_bytes{job=\"api\"}",
          "legendFormat": "Used"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nodejs_heap_size_total_bytes{job=\"api\"}",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 12,
      "title": "GC duration p95",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, kind) (rate(nodejs_gc_duration_seconds_bucket{job=\"api\"}[5m])))",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "id": 13,
      "title": "Tenant request rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (tenant_slug) (rate(http_requests_total{tenant_slug=~\"$tenant\"}[5m]))",
          "legendFormat": "{{tenant_slug}}"
        }
      ]
    },
    {
      "id": 14,
      "title": "Tenant p95 request duration",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, tenant_slug) (rate(http_request_duration_seconds_bucket{tenant_slug=~\"$tenant\"}[5m])))",
          "legendFormat": "{{tenant_slug}}"
        }
      ]
    },
    {
      "id": 15,
      "title": "Tenant usage summary",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 34 },
      "targets": [
        {
          "refId": "Requests",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (tenant_slug) (increase(http_requests_total{tenant_slug=~\"$tenant\"}[$__range]))",
          "format": "table",
          "instant": true,
          "legendFormat": "requests"
        },
        {
          "refId": "Errors",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (tenant_slug) (increase(http_requests_total{tenant_slug=~\"$tenant\", status_code=~\"5..\"}[$__range]))",
          "format": "table",
          "instant": true,
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 3,
      "title": "Recent logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 42 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{app=\"api\", env=~\"$env\", level=~\"$level\"} | json | req_method=~\"$method\" | res_statusCode=~\"$status\" |~ \"$search\""
        }
      ]
    }
  ]
}
